#!/usr/bin/env bash
# pre-commit gate — admits st-commit-driven commits and legitimate
# derived-commit workflows; rejects raw `git commit`.
#
# Source-of-truth contract: docs/specs/host-level-tool.md "Git hooks".
# Companion: src/standard_tooling/bin/commit.py sets ST_COMMIT_CONTEXT=1
# before invoking `git commit`.
#
# TODO(plugin#87): the "See ..." pointer below references
# docs/repository-standards.md (markdown). When standard-tooling-plugin
# #87's structured config (st-config.{yml,toml}) lands, update this
# pointer to the new config doc.

# Admit st-commit-driven commits.
if [[ "${ST_COMMIT_CONTEXT:-}" == "1" ]]; then exit 0; fi

# Admit derived-commit workflows that legitimately invoke `git commit`
# without going through st-commit (amend, rebase, cherry-pick, revert,
# merge-conflict resolution). GIT_REFLOG_ACTION is set by git itself.
case "${GIT_REFLOG_ACTION:-}" in
amend | cherry-pick | revert | rebase* | merge*) exit 0 ;;
esac

echo "ERROR: raw 'git commit' is blocked. Use 'st-commit' instead." >&2
echo "See docs/repository-standards.md" >&2
exit 1
