#!/usr/bin/env bash
# Managed by standard-tooling — DO NOT EDIT in downstream repos.
# Canonical source: https://github.com/wphillipmoore/standard-tooling
set -euo pipefail

# Collect MkDocs documentation sources — the only markdown files subject to
# both markdownlint and structural checks (single-H1, Table of Contents,
# heading-level progression).
#
# Everything outside docs/site/ is out of scope: CLAUDE.md, AGENTS.md,
# skills/, agents/, fragments/, drafts/, CHANGELOG.md, releases/, etc.
# Those files are operational config or auto-generated and are not
# published documentation.

files=()

for docsite_dir in docs/site docs/sphinx; do
  if [[ -d "$docsite_dir" ]]; then
    while IFS= read -r file; do
      files+=("$file")
    done < <(find "$docsite_dir" -type f -name "*.md")
  fi
done

if [[ -f README.md ]]; then
  files+=("README.md")
fi

if [[ ${#files[@]} -eq 0 ]]; then
  echo "No documentation files found to lint (checked docs/site/, docs/sphinx/, README.md)."
  exit 0
fi

if command -v markdownlint >/dev/null 2>&1; then
  markdownlint_cmd=(markdownlint)
else
  echo "ERROR: markdownlint not found. Install markdownlint-cli locally." >&2
  exit 2
fi

markdownlint_failed=0
if [[ -f ".markdownlint.yaml" ]]; then
  if ! "${markdownlint_cmd[@]}" --config ".markdownlint.yaml" "${files[@]}"; then
    markdownlint_failed=1
  fi
else
  if ! "${markdownlint_cmd[@]}" "${files[@]}"; then
    markdownlint_failed=1
  fi
fi

failed=0

for file in "${files[@]}"; do
  awk -v file="$file" '
    BEGIN {
      in_code = 0
      toc_found = 0
      h1_count = 0
      last_level = 0
      errors = 0
    }
    function report(message) {
      printf "ERROR: %s (%s:%d)\n", message, file, NR > "/dev/stderr"
      errors = 1
    }
    {
      line = $0

      if (match(line, /^```/) || match(line, /^~~~/)) {
        in_code = !in_code
      }

      if (in_code) {
        next
      }

      if (line ~ /^## Table of Contents[[:space:]]*$/) {
        toc_found = 1
      }

      if (line ~ /^#{1,6} /) {
        level = length(substr(line, 1, match(line, / /) - 1))
        if (level == 1) {
          h1_count += 1
        }
        if (last_level > 0 && level > last_level + 1) {
          report("Heading level skips from " last_level " to " level)
        }
        last_level = level
      }
    }
    END {
      if (h1_count != 1) {
        printf "ERROR: expected exactly one H1 heading, found %d (%s)\n", h1_count, file > "/dev/stderr"
        errors = 1
      }
      if (toc_found != 1) {
        printf "ERROR: missing ## Table of Contents (%s)\n", file > "/dev/stderr"
        errors = 1
      }
      exit errors
    }
  ' "$file" || failed=1

done

exit $((failed || markdownlint_failed))
